# EmailJS Configuration
# Copia este archivo a .env.local y reemplaza con tus credenciales reales

# Service ID de EmailJS (ej: service_abc123)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_b27e4ra

# Template ID de EmailJS (ej: template_xyz789)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_ez82hdt

# Public Key de EmailJS (ej: user_abc123def456)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=RlMd41GVffFjQbiY7

# Nota: Para obtener estas credenciales:
# 1. Ve a https://www.emailjs.com/
# 2. Crea una cuenta gratuita
# 3. Configura un servicio de email (Gmail, Outlook, etc.)
# 4. Crea un template de email
# 5. Obtén tu Public Key desde Account > API Keys
